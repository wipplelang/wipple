Color : type {color :: String}

color-widget :: String -> Color
color-widget : color -> Color {color : color}

instance (Random () Color) : () -> do {
  red : floor (random-in (0 to 256))
  green : floor (random-in (0 to 256))
  blue : floor (random-in (0 to 256))
  Color {color : '{"color":"rgb(_,_,_)"}' red green blue}
}

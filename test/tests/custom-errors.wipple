-- wipple compile $FILE --facts

[intrinsic] Number : type
[intrinsic] String : type

Add : left right (infer sum) => trait (left right -> sum)
instance (Add Number Number Number) : _
instance (Add String String String) : _

-- Missing parentheses around the inputs to `+`.
[error] instance (Add () right sum)

-- Cannot add [`left`] and [`right`].
[default] [error] instance (Add left right sum)

_ : 1 + 2
_ : "a" + "b"
_ : 1 + "a"
_ : () + 2
